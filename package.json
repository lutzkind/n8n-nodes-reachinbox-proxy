{
  "name": "n8n-nodes-reachinbox-proxy",
  "version": "1.1.1",
  "description": "n8n community node for ReachInbox — works with self-hosted proxy, no API key required",
  "keywords": ["n8n-community-node-package", "reachinbox", "email", "outreach"],
  "license": "MIT",
  "homepage": "https://github.com/lutzkind/n8n-nodes-reachinbox-proxy",
  "author": { "name": "lutzkind" },
  "repository": { "type": "git", "url": "https://github.com/lutzkind/n8n-nodes-reachinbox-proxy.git" },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "prepublishOnly": "npm run build && npm run lint -c .eslintrc.prepublish.json"
  },
  "files": ["dist"],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": ["dist/credentials/ReachInboxProxyApi.credentials.js"],
    "nodes": [
      "dist/nodes/ReachInbox/ReachInbox.node.js",
      "dist/nodes/ReachInbox/ReachInboxTrigger.node.js"
    ]
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "n8n-workflow": "*",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
